{
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.formatOnSave": true,
  "editor.formatOnPaste": false,
  "editor.formatOnSaveMode": "file",
  "editor.tabSize": 2,
  "editor.insertSpaces": true,
  "editor.codeActionsOnSave": {
    "source.fixAll": "never",
    "source.fixAll.eslint": "never",
    "source.organizeImports": "never",
    "source.sortImports": "never"
  },
  "eslint.format.enable": false,
  "eslint.useFlatConfig": true,
  "eslint.validate": [
    "javascript",
    "javascriptreact",
    "typescript",
    "typescriptreact"
  ],
  "prettier.requireConfig": true,
  "js/ts.inlayHints.parameterNames.enabled": "literals",
  "js/ts.inlayHints.variableTypes.enabled": true,
  "js/ts.inlayHints.propertyDeclarationTypes.enabled": true,
  "js/ts.inlayHints.functionLikeReturnTypes.enabled": true,
  "tailwindCSS.classAttributes": [
    "class",
    "className",
    "classList",
    "ngClass"
  ],
  "tailwindCSS.lint.cssConflict": "warning",
  "explorer.fileNesting.enabled": true,
  "explorer.fileNesting.patterns": {
    "*.ts": "${capture}.test.ts, ${capture}.spec.ts, ${capture}.mock.ts",
    "*.tsx": "${capture}.test.tsx, ${capture}.spec.tsx, ${capture}.stories.tsx"
  },
  "search.exclude": {
    "**/.nx": true,
    "**/dist": true,
    "**/coverage": true,
    "**/test-output": true
  },
  "files.watcherExclude": {
    "**/.nx/cache/**": true,
    "**/dist/**": true,
    "**/coverage/**": true,
    "**/test-output/**": true
  },
  "editor.rulers": [
    80,
    100
  ],
  "breadcrumbs.enabled": true,
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[javascriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "editor.bracketPairColorization.independentColorPoolPerBracketType": true,
  "typescript.tsdk.path": "node_modules\\typescript\\lib"
}