# Set the default behavior, in case people don't have core.autocrlf set.
* text=auto eol=crlf

# Explicitly declare text files you want to always be normalized and converted
# to CRLF line endings on checkout.
*.ts text eol=crlf
*.tsx text eol=crlf
*.js text eol=crlf
*.jsx text eol=crlf
*.json text eol=crlf
*.css text eol=crlf
*.scss text eol=crlf
*.html text eol=crlf
*.md text eol=crlf
*.yml text eol=crlf
*.yaml text eol=crlf

# Denote all files that are truly binary and should not be modified.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.svg binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.otf binary
