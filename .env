# Manager Mode Configuration
# Set to "mock" for development with mock data, or "api" for production
VITE_MANAGER_MODE=mock

# API Base URL (required when mode is "api")
# Note: Some endpoints include /api prefix (e.g., /api/users), while auth endpoints don't (e.g., /auth/login)
VITE_API_BASE_URL=https://api.kdz.asia